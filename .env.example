# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
ALLOWED_CHATS=              # Optional: comma-separated chat IDs

# API Keys (optional, for better reliability)
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Cookies for authenticated scraping (Facebook, Instagram, YouTube)
# Option 1: Export cookies from your browser using a browser extension, save as cookies.txt
COOKIES_FILE=
# Option 2: Auto-extract cookies from browser (e.g. chrome, firefox, edge)
COOKIES_FROM_BROWSER=

# yt-dlp JavaScript runtime for YouTube extraction (required since yt-dlp 2025+)
# Install deno: https://deno.land/#installation — then set this to "deno"
YTDLP_JS_RUNTIME=deno

# Performance
MAX_FILE_SIZE_MB=50
DOWNLOAD_TIMEOUT_SECONDS=30
CONCURRENT_DOWNLOADS=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
